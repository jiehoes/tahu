# Tahu — Environment Variables
# Copy to .env and fill in your values

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# D1 Database
D1_DATABASE_ID=
D1_DATABASE_NAME=tahu-db

# R2
R2_BUCKET_NAME=tahu-documents

# Auth
JWT_SECRET=change-me-in-production-use-random-64-chars
API_KEY=

# App
LOG_LEVEL=debug
